@model SalesTrackAcademy.Models.ViewModels.AgentDashboardVm
@{
    ViewData["Title"] = "My Learning";
}

<section class="page-head">
    <h1><i class="bi bi-mortarboard me-2"></i>My Learning Dashboard</h1>
    <p>Track assigned courses, continue where you left off, and complete certification paths.</p>
</section>

<div class="row g-4">
@foreach (var course in Model.AssignedCourses)
{
    <div class="col-md-6 col-xl-4">
        <article class="course-card agent">
            <img src="@(string.IsNullOrWhiteSpace(course.ThumbnailUrl) ? "https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?auto=format&fit=crop&w=900&q=80" : course.ThumbnailUrl)" alt="@course.Title" />
            <div class="content">
                <div class="d-flex justify-content-between align-items-start gap-2">
                    <h3>@course.Title</h3>
                    <span class="status-pill @(course.IsCompleted ? "done" : "active")">@(course.IsCompleted ? "Completed" : "In Progress")</span>
                </div>
                <p>@course.Description</p>
                <div class="progress-shell">
                    <div class="progress" role="progressbar" aria-valuenow="@course.ProgressPercent" aria-valuemin="0" aria-valuemax="100">
                        <div class="progress-bar" style="width: @course.ProgressPercent%"></div>
                    </div>
                    <small>@course.ProgressPercent% complete</small>
                </div>
                <a asp-action="Course" asp-route-id="@course.CourseId" class="btn btn-dark btn-sm mt-2"><i class="bi bi-play-circle me-1"></i>Open Course</a>
            </div>
        </article>
    </div>
}
</div>
