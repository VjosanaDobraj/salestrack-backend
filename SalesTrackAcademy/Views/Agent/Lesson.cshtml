@model SalesTrackAcademy.Models.ViewModels.LessonPlayerVm
@{
    ViewData["Title"] = Model.LessonTitle;
}

<section class="page-head">
    <h1><i class="bi bi-play-btn me-2"></i>@Model.LessonTitle</h1>
    <p>@Model.CourseTitle</p>
</section>

<section class="lesson-meta-bar mb-4">
    <span><i class="bi bi-collection-play me-1"></i>@Model.LessonType</span>
    <span><i class="bi bi-shield-check me-1"></i>Passing: @(Model.PassingScorePercent?.ToString() ?? "N/A")%</span>
    <span><i class="bi bi-patch-check me-1"></i>Status: @(Model.IsCompleted ? "Completed" : "In Progress")</span>
</section>

@if (TempData["QuizResult"] is string quizResult)
{
    <div class="alert alert-info">@quizResult</div>
}

<div class="row g-4">
    <div class="col-lg-8">
        <section class="card-surface card-glow">
            <h2 class="h4">Lesson Player</h2>
            @if (Model.LessonType == SalesTrackAcademy.Models.LessonType.Video)
            {
                <div class="ratio ratio-16x9">
                    @if (!string.IsNullOrWhiteSpace(Model.ContentUrl) && Model.ContentUrl.Contains("youtube"))
                    {
                        <iframe src="@Model.ContentUrl" allowfullscreen></iframe>
                    }
                    else
                    {
                        <video controls src="@Model.ContentUrl" class="w-100"></video>
                    }
                </div>
            }
            else if (Model.LessonType == SalesTrackAcademy.Models.LessonType.Audio)
            {
                <audio controls class="w-100" src="@Model.ContentUrl"></audio>
            }
            else if (Model.LessonType == SalesTrackAcademy.Models.LessonType.Pdf)
            {
                <iframe src="@Model.ContentUrl" style="width:100%;height:600px;border:0;"></iframe>
            }
            else
            {
                <article class="text-lesson">@Model.TextContent</article>
            }

            @if (!Model.IsCompleted)
            {
                <form asp-action="CompleteLesson" method="post" class="mt-3">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="lessonId" value="@Model.LessonId" />
                    <button class="btn btn-outline-dark" type="submit"><i class="bi bi-check2-circle me-1"></i>Mark Lesson Completed</button>
                </form>
            }
            else
            {
                <div class="alert alert-success mt-3">Completed</div>
            }
        </section>

        <section class="card-surface mt-4 card-glow">
            <h2 class="h4">Comments</h2>
            <form asp-action="AddComment" method="post" class="mb-3">
                @Html.AntiForgeryToken()
                <input type="hidden" name="LessonId" value="@Model.LessonId" />
                <textarea class="form-control" name="Body" rows="3" placeholder="Ask a question or share feedback" required></textarea>
                <button class="btn btn-primary mt-2" type="submit"><i class="bi bi-send me-1"></i>Post Comment</button>
            </form>

            <div class="comment-feed">
                @foreach (var comment in Model.Comments)
                {
                    <article class="comment-item">
                        <header>
                            <strong>@(comment.Agent?.FullName ?? comment.Agent?.Email ?? "Agent")</strong>
                            <small>@comment.CreatedAtUtc.ToLocalTime().ToString("g")</small>
                        </header>
                        <p>@comment.Body</p>
                    </article>
                }
            </div>
        </section>
    </div>

    <div class="col-lg-4">
        <section class="card-surface card-glow quiz-sticky">
            <h2 class="h4">Quiz</h2>
            @if (Model.QuizQuestions.Count == 0)
            {
                <p class="text-muted">No quiz for this lesson.</p>
            }
            else
            {
                <form asp-action="SubmitQuiz" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="lessonId" value="@Model.LessonId" />
                    @foreach (var question in Model.QuizQuestions)
                    {
                        <article class="quiz-question">
                            <h3>@question.Prompt</h3>
                            @foreach (var option in question.Options)
                            {
                                <label class="option-line">
                                    <input type="radio" name="answer_@question.Id" value="@option.Id" required />
                                    <span>@option.OptionText</span>
                                </label>
                            }
                        </article>
                    }
                    <button class="btn btn-dark" type="submit"><i class="bi bi-check2-square me-1"></i>Submit Quiz</button>
                    @if (Model.PassingScorePercent.HasValue)
                    {
                        <p class="small text-muted mt-2">Passing score: @Model.PassingScorePercent%</p>
                    }
                </form>
            }
        </section>
    </div>
</div>
