@{
    ViewData["Title"] = "SalesTrack Academy";
}

<section class="hero-v2">
    <div class="hero-copy">
        <p class="eyebrow">Sales Performance Academy</p>
        <h1>Build high-performing reps with measurable learning outcomes.</h1>
        <p>
            A focused training command center for modern sales teams. Build modules, assign cohorts,
            score understanding, and track progress in one place.
        </p>
        <div class="hero-actions">
            <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-dark btn-lg">Launch Platform</a>
            <a asp-controller="Home" asp-action="Privacy" class="btn btn-outline-dark btn-lg">Security</a>
        </div>
    </div>
    <aside class="hero-panel hero-panel-credentials">
        <h2>Demo Credentials</h2>
        <div class="credential-item">
            <span>Admin</span>
            <p>admin@salestrack.local<br />Temp123!</p>
        </div>
        <div class="credential-item">
            <span>Agent</span>
            <p>agent.a@salestrack.local<br />Temp123!</p>
        </div>
    </aside>
</section>

<section class="feature-ribbon mt-4">
    <article>
        <i class="bi bi-camera-video"></i>
        <h3>Media-First Lessons</h3>
        <p>Video, audio, PDF, and text modules in one flow.</p>
    </article>
    <article>
        <i class="bi bi-ui-checks-grid"></i>
        <h3>Quiz & Passing Logic</h3>
        <p>MCQ assessments with passing-score progression rules.</p>
    </article>
    <article>
        <i class="bi bi-graph-up"></i>
        <h3>Live Visibility</h3>
        <p>Completion, accuracy, and engagement analytics for managers.</p>
    </article>
</section>
