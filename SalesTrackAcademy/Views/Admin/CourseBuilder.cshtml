@model SalesTrackAcademy.Models.Course
@using SalesTrackAcademy.Models
@{
    ViewData["Title"] = "Course Builder";
    var agents = ViewBag.Agents as IList<ApplicationUser> ?? [];
    var groups = ViewBag.Groups as IList<AgentGroup> ?? [];
}

<section class="page-head">
    <h1><i class="bi bi-sliders2-vertical me-2"></i>@Model.Title</h1>
    <p>@Model.Description</p>
</section>

<div class="row g-4">
    <div class="col-lg-7">
        <section class="card-surface card-glow">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <h2 class="h4 mb-0">Lesson Timeline</h2>
                <span class="subtle-pill">@Model.Lessons.Count lesson(s)</span>
            </div>
            <p class="text-muted">Drag to reorder, or use quick move buttons.</p>
            <ul id="lesson-list" class="lesson-list">
                @foreach (var lesson in Model.Lessons.OrderBy(x => x.SortOrder))
                {
                    <li draggable="true" data-id="@lesson.Id" class="lesson-row">
                        <div>
                            <strong>@lesson.Title</strong>
                            <div class="small text-muted">@lesson.LessonType | Passing: @(lesson.PassingScorePercent?.ToString() ?? "N/A")%</div>
                        </div>
                        <div class="d-flex gap-2">
                            <a asp-controller="Agent" asp-action="Lesson" asp-route-id="@lesson.Id" class="btn btn-sm btn-outline-dark">Preview</a>
                            <form asp-action="MoveLesson" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="lessonId" value="@lesson.Id" />
                                <input type="hidden" name="moveUp" value="true" />
                                <button class="btn btn-sm btn-outline-secondary" type="submit">Up</button>
                            </form>
                            <form asp-action="MoveLesson" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="lessonId" value="@lesson.Id" />
                                <input type="hidden" name="moveUp" value="false" />
                                <button class="btn btn-sm btn-outline-secondary" type="submit">Down</button>
                            </form>
                        </div>
                    </li>
                }
            </ul>
            <form asp-action="ReorderLessons" method="post" id="reorder-form" class="mt-3">
                @Html.AntiForgeryToken()
                <input type="hidden" name="courseId" value="@Model.Id" />
                <input type="hidden" name="orderedLessonIds" id="ordered-ids" />
                <button class="btn btn-dark" type="submit"><i class="bi bi-check2-circle me-1"></i>Save Drag Order</button>
            </form>
        </section>

        <section class="card-surface mt-4 card-glow">
            <h2 class="h4">Add Lesson</h2>
            <form asp-action="AddLesson" method="post" class="row g-3">
                @Html.AntiForgeryToken()
                <input type="hidden" name="CourseId" value="@Model.Id" />
                <div class="col-12">
                    <label class="form-label">Title</label>
                    <input class="form-control" name="Title" required />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Lesson Type</label>
                    <select class="form-select" name="LessonType" asp-items="Html.GetEnumSelectList<LessonType>()"></select>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Passing Score (%)</label>
                    <input class="form-control" name="PassingScorePercent" type="number" min="1" max="100" />
                </div>
                <div class="col-12">
                    <label class="form-label">Media URL / PDF URL</label>
                    <input class="form-control" name="ContentUrl" />
                </div>
                <div class="col-12">
                    <label class="form-label">Text Content</label>
                    <textarea class="form-control" name="TextContent" rows="4"></textarea>
                </div>
                <div class="col-12">
                    <button class="btn btn-primary" type="submit"><i class="bi bi-plus-circle me-1"></i>Add Lesson</button>
                </div>
            </form>
        </section>
    </div>

    <div class="col-lg-5">
        <section class="card-surface card-glow">
            <h2 class="h4">Assign Course</h2>
            <form asp-action="AssignCourse" method="post" class="row g-3">
                @Html.AntiForgeryToken()
                <input type="hidden" name="CourseId" value="@Model.Id" />
                <div class="col-12">
                    <label class="form-label">Agents</label>
                    <select class="form-select" name="AgentIds" multiple size="6">
                        @foreach (var agent in agents)
                        {
                            <option value="@agent.Id">@agent.FullName (@agent.Email)</option>
                        }
                    </select>
                </div>
                <div class="col-12">
                    <label class="form-label">Groups</label>
                    <select class="form-select" name="GroupIds" multiple size="4">
                        @foreach (var group in groups)
                        {
                            <option value="@group.Id">@group.Name (@group.Memberships.Count members)</option>
                        }
                    </select>
                </div>
                <div class="col-12"><button class="btn btn-primary" type="submit">Assign</button></div>
            </form>
        </section>

        <section class="card-surface mt-4 card-glow">
            <h2 class="h4">Create Group</h2>
            <form asp-action="CreateGroup" method="post" class="row g-3">
                @Html.AntiForgeryToken()
                <div class="col-12">
                    <label class="form-label">Group Name</label>
                    <input class="form-control" name="Name" required />
                </div>
                <div class="col-12">
                    <label class="form-label">Members</label>
                    <select class="form-select" name="AgentIds" multiple size="6">
                        @foreach (var agent in agents)
                        {
                            <option value="@agent.Id">@agent.FullName (@agent.Email)</option>
                        }
                    </select>
                </div>
                <div class="col-12"><button class="btn btn-outline-dark" type="submit"><i class="bi bi-people me-1"></i>Create Group</button></div>
            </form>
        </section>

        <section class="card-surface mt-4 card-glow">
            <h2 class="h4">Quiz Builder</h2>
            <p class="text-muted">Add MCQs to any lesson.</p>
            <form asp-action="AddQuizQuestion" method="post" class="row g-3">
                @Html.AntiForgeryToken()
                <div class="col-12">
                    <label class="form-label">Lesson</label>
                    <select class="form-select" name="LessonId">
                        @foreach (var lesson in Model.Lessons.OrderBy(x => x.SortOrder))
                        {
                            <option value="@lesson.Id">@lesson.Title</option>
                        }
                    </select>
                </div>
                <div class="col-12">
                    <label class="form-label">Question</label>
                    <textarea class="form-control" name="Prompt" required rows="3"></textarea>
                </div>
                <div class="col-12"><input class="form-control" name="OptionA" placeholder="Option 1" required /></div>
                <div class="col-12"><input class="form-control" name="OptionB" placeholder="Option 2" required /></div>
                <div class="col-12"><input class="form-control" name="OptionC" placeholder="Option 3" required /></div>
                <div class="col-12"><input class="form-control" name="OptionD" placeholder="Option 4" required /></div>
                <div class="col-12">
                    <label class="form-label">Correct Option</label>
                    <select class="form-select" name="CorrectOption">
                        <option value="1">Option 1</option>
                        <option value="2">Option 2</option>
                        <option value="3">Option 3</option>
                        <option value="4">Option 4</option>
                    </select>
                </div>
                <div class="col-12"><button class="btn btn-primary" type="submit"><i class="bi bi-patch-question me-1"></i>Add MCQ</button></div>
            </form>
        </section>
    </div>
</div>

@section Scripts {
<script>
    (() => {
        const list = document.getElementById("lesson-list");
        const hidden = document.getElementById("ordered-ids");
        if (!list || !hidden) return;

        let dragged = null;
        const getRows = () => [...list.querySelectorAll(".lesson-row")];

        const syncIds = () => {
            hidden.value = getRows().map(x => x.dataset.id).join(",");
        };

        list.addEventListener("dragstart", e => {
            dragged = e.target.closest(".lesson-row");
        });

        list.addEventListener("dragover", e => {
            e.preventDefault();
            const target = e.target.closest(".lesson-row");
            if (!dragged || !target || dragged === target) return;
            const rows = getRows();
            const draggedIndex = rows.indexOf(dragged);
            const targetIndex = rows.indexOf(target);
            if (draggedIndex < targetIndex) {
                target.after(dragged);
            } else {
                target.before(dragged);
            }
            syncIds();
        });

        syncIds();
    })();
</script>
}
